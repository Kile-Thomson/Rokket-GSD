# ── Universal .dropboxignore for GSD projects ──
# Prevents Dropbox sync storms from dependencies, build output, and transient data.
# .gsd/ itself SYNCS — only transient/regenerated subdirs are excluded.

# Dependencies (the #1 offender — thousands of tiny files)
node_modules
**/node_modules
.pnpm-store

# Build output
.next
**/dist
build
out
.output
.nuxt
.svelte-kit

# GSD transient (regenerated, not worth syncing)
.gsd/worktrees
.gsd/activity
.gsd/forensics
.gsd/parallel
.gsd/runtime
.gsd/gsd.db

# Caches
.cache
.turbo
.parcel-cache
.eslintcache
tsconfig.tsbuildinfo

# Generated code
src/generated
.prisma

# Package managers
.yarn/cache
.yarn/unplugged
.pnp.*

# Python (if applicable)
__pycache__
.venv
venv
*.pyc

# Misc
coverage
.sst
*.sst
